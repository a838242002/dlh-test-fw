{
  "title": "DLH — History",
  "uid": "dlh-history",
  "schemaVersion": 39,
  "tags": ["dlh"],
  "timezone": "",
  "time": { "from": "now-7d", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "label": "Scenario filter",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
        "query": { "query": "label_values(dlh_verdict_overall, dlh_scenario)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "type": "table",
      "title": "Recent verdict runs",
      "description": "One row per scenario run. Sourced from `dlh_verdict_overall` + `dlh_verdict_chaos_pass` pushed by verdict-job at end-of-run.",
      "targets": [
        { "expr": "dlh_verdict_overall{dlh_scenario=~\"$scenario\"}", "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" }, "format": "table", "instant": true, "refId": "A" },
        { "expr": "dlh_verdict_chaos_pass{dlh_scenario=~\"$scenario\"}", "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" }, "format": "table", "instant": true, "refId": "B" }
      ],
      "transformations": [
        { "id": "merge" },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true },
            "renameByName": {
              "dlh_workflow": "workflow",
              "dlh_scenario": "scenario",
              "Value #A": "overall",
              "Value #B": "chaos_pass"
            },
            "indexByName": { "dlh_workflow": 0, "dlh_scenario": 1, "Value #A": 2, "Value #B": 3 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "overall" },
            "properties": [
              { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "FAIL", "color": "red" }, "1": { "text": "PASS", "color": "green" } } } ] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "chaos_pass" },
            "properties": [
              { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "NOT PASS", "color": "red" }, "1": { "text": "PASS", "color": "green" } } } ] },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } }
            ]
          }
        ]
      },
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 }
    },
    {
      "type": "stat",
      "title": "Pass rate by scenario (last 7d)",
      "description": "Average of dlh_verdict_overall over the dashboard time range — 1.0 means every run in the window passed.",
      "targets": [
        { "expr": "avg by (dlh_scenario) (avg_over_time(dlh_verdict_overall{dlh_scenario=~\"$scenario\"}[$__range]))", "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" }, "instant": true, "legendFormat": "{{dlh_scenario}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.8 }, { "color": "green", "value": 1.0 } ] }
        }
      },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 }
    },
    {
      "type": "stat",
      "title": "Total runs by scenario (last 7d)",
      "description": "Count of distinct workflows that produced a verdict per scenario.",
      "targets": [
        { "expr": "count by (dlh_scenario) (group by (dlh_workflow, dlh_scenario) (dlh_verdict_overall{dlh_scenario=~\"$scenario\"}))", "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" }, "instant": true, "legendFormat": "{{dlh_scenario}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value_and_name", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 }
    },
    {
      "type": "timeseries",
      "title": "Mean p95 latency over last 7d (per scenario)",
      "targets": [
        { "expr": "avg by (dlh_scenario) (k6_http_req_duration_p95{dlh_scenario=~\"$scenario\"})", "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" } }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 }
    }
  ]
}
