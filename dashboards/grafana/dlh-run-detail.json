{
  "title": "DLH — Run Detail",
  "uid": "dlh-run",
  "schemaVersion": 39,
  "tags": ["dlh"],
  "timezone": "",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "label": "Scenario label",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
        "query": { "query": "label_values(k6_http_reqs_total, dlh_scenario)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "workflow",
        "label": "Workflow",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" },
        "query": { "query": "label_values(k6_http_reqs_total{dlh_scenario=\"$scenario\"}, dlh_workflow)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 5,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "k6 HTTP req rate",
      "targets": [
        {
          "expr": "sum by (status) (rate(k6_http_reqs_total{dlh_scenario=\"$scenario\"}[30s]))",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" }
        }
      ],
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "k6 p95 latency",
      "targets": [
        {
          "expr": "avg(k6_http_req_duration_p95{dlh_scenario=\"$scenario\"})",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" }
        }
      ],
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "type": "timeseries",
      "title": "k6 error rate (non-2xx)",
      "targets": [
        {
          "expr": "sum(rate(k6_http_reqs_total{dlh_scenario=\"$scenario\",status!~\"2..\"}[30s])) / clamp_min(sum(rate(k6_http_reqs_total{dlh_scenario=\"$scenario\"}[30s])), 1e-9)",
          "datasource": { "type": "prometheus", "uid": "VictoriaMetrics" }
        }
      ],
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "type": "stat",
      "title": "Verdict summary (dlh-result-$workflow)",
      "targets": [
        {
          "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "Infinity" },
          "type": "json",
          "source": "url",
          "url": "http://kubernetes.default.svc/api/v1/namespaces/dlh-test-fw/configmaps/dlh-result-$workflow",
          "root_selector": "data['result.json']"
        }
      ],
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    }
  ]
}
