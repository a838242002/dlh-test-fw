{
  "title": "DLH \u2014 Run Detail",
  "uid": "dlh-run",
  "schemaVersion": 39,
  "tags": [
    "dlh"
  ],
  "timezone": "",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "scenario",
        "label": "Scenario label",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "VictoriaMetrics"
        },
        "query": {
          "query": "label_values(dlh_verdict_overall, dlh_scenario)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "workflow",
        "label": "Workflow",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "VictoriaMetrics"
        },
        "query": {
          "query": "label_values(dlh_verdict_overall{dlh_scenario=\"$scenario\"}, dlh_workflow)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 5,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "k6 iteration rate",
      "description": "Generic k6 throughput; counts completed iterations/sec regardless of protocol (HTTP, mysql, kafka, ...).",
      "targets": [
        {
          "expr": "sum(rate(k6_iterations_total{dlh_workflow=\"$workflow\"}[30s]))",
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "legendFormat": "iterations/s"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "k6 iteration p95",
      "description": "Generic k6 latency p95 (per-iteration duration in ms, as k6 emits).",
      "targets": [
        {
          "expr": "k6_iteration_duration_p95{dlh_workflow=\"$workflow\"}",
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 8
      }
    },
    {
      "type": "timeseries",
      "title": "k6 app errors by kind",
      "description": "Protocol-aware error counter from our runners (mysql.*, kafka-*, ...).",
      "targets": [
        {
          "expr": "sum by (kind) (rate(k6_dlh_app_errors_total_total{dlh_workflow=\"$workflow\"}[30s]))",
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "legendFormat": "{{kind}}"
        }
      ],
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 8
      }
    },
    {
      "type": "stat",
      "title": "Verdict \u2014 overall",
      "description": "1 = pass, 0 = fail. Pushed by verdict-job to VictoriaMetrics under labels dlh_workflow + dlh_scenario.",
      "targets": [
        {
          "expr": "last_over_time(dlh_verdict_overall{dlh_workflow=\"$workflow\"}[7d])",
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red"
                },
                "1": {
                  "text": "PASS",
                  "color": "green"
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 24,
        "h": 5
      }
    },
    {
      "type": "table",
      "title": "Verdict \u2014 SLO thresholds",
      "description": "One row per threshold defined in the scenario's SLO YAML; pass = 1 means the threshold was met.",
      "targets": [
        {
          "expr": "last_over_time(dlh_verdict_threshold_pass{dlh_workflow=\"$workflow\"}[7d])",
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "format": "table",
          "instant": true,
          "refId": "A"
        },
        {
          "expr": "last_over_time(dlh_verdict_threshold_value{dlh_workflow=\"$workflow\"}[7d])",
          "datasource": {
            "type": "prometheus",
            "uid": "VictoriaMetrics"
          },
          "format": "table",
          "instant": true,
          "refId": "B"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "name",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "dlh_workflow": true,
              "dlh_workflow 1": true,
              "dlh_workflow 2": true,
              "dlh_scenario": true,
              "dlh_scenario 1": true,
              "dlh_scenario 2": true
            },
            "renameByName": {
              "name": "threshold",
              "Value #A": "pass",
              "Value #B": "value"
            },
            "indexByName": {
              "name": 0,
              "Value #A": 1,
              "Value #B": 2
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "pass"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "FAIL",
                        "color": "red"
                      },
                      "1": {
                        "text": "PASS",
                        "color": "green"
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 8
      }
    }
  ],
  "links": [
    {
      "title": "Open in MySQL",
      "type": "link",
      "icon": "external link",
      "tags": [],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true,
      "url": "/d/dlh-mysql/",
      "targetBlank": false
    },
    {
      "title": "Open in Kafka",
      "type": "link",
      "icon": "external link",
      "tags": [],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true,
      "url": "/d/dlh-kafka/",
      "targetBlank": false
    },
    {
      "title": "Open in Doris",
      "type": "link",
      "icon": "external link",
      "tags": [],
      "asDropdown": false,
      "includeVars": true,
      "keepTime": true,
      "url": "/d/dlh-doris/",
      "targetBlank": false
    }
  ]
}
